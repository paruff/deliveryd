# Environment Configuration for deliveryd
# Copy this file to .env and customize for your environment

# DockerHub Credentials
DOCKERHUB_USERNAME=your-dockerhub-username
DOCKERHUB_TOKEN=your-dockerhub-token-or-password

# SonarQube Database Password
SONAR_DB_PASSWORD=sonar

# Jenkins Admin Credentials
JENKINS_ADMIN_USER=admin
JENKINS_ADMIN_PASSWORD=changeme

# Default Builder for Cloud Native Buildpacks
CNB_BUILDER=paketobuildpacks/builder:base

# Registry Configuration
DOCKER_REGISTRY=docker.io
REGISTRY_NAMESPACE=${DOCKERHUB_USERNAME}

# Kubernetes Configuration (for promotion path)
# K8S_CLUSTER_URL=https://kubernetes.default.svc
# K8S_NAMESPACE=deliveryd
# K8S_SERVICE_ACCOUNT_TOKEN=

# Webhook Secret for External Triggers
WEBHOOK_SECRET=changeme-random-string

# Optional: Slack/Teams Notifications
# SLACK_WEBHOOK_URL=
# TEAMS_WEBHOOK_URL=
